{
  "Not When Sourced": {
    "prefix": "NWS",
    "body": [
      "if [[ \"\\${BASH_SOURCE[0]}\" == \"\\$0\" ]]; then",
      "  $1",
      "fi\n$0"
    ],
    "description": "not when sourced"
  },
  "ShellCheck Disable Line": {
    "prefix": "SDL",
    "body": ["# shellcheck disable=SC$1"],
    "description": "shellcheck disable line"
  },
  "Universal Bash Shebang": {
    "prefix": "UBS",
    "body": ["#!/usr/bin/env bash\n$0"],
    "description": "universal bash shebang"
  },
  "Log Error Level": {
    "prefix": "LEL",
    "body": [
      "_log_error() {",
      "  if [[ -t 2 ]]; then",
      "    printf \"\033[31m%s\033[0m\n\" \"$@\" >&2",
      "  else",
      "    printf \"%s\n\" \"$@\" >&2",
      "  fi",
      "}"
    ],
    "description": "log at error level"
  },
  "Log Info Level": {
    "prefix": "LIL",
    "body": [
      "_log_info() {",
      "  if [[ -t 1 ]]; then",
      "    printf \"\033[36m%s\033[0m\n\" \"$@\"",
      "  else",
      "    printf \"%s\n\" \"$@\"",
      "  fi",
      "}"
    ],
    "description": "log at info level"
  },
  "Shell Modeline": {
    "prefix": "SHM",
    "body": ["# vim: set ft=sh :"],
    "description": "shell modeline"
  },
  "Set Shell Options": {
    "prefix": "EUP",
    "body": ["set -eu -o pipefail"],
    "description": "set shell options"
  },
  "Current Script Directory": {
    "prefix": "CSD",
    "body": [
      "\"$(cd \"$(dirname \"$(readlink -f \"${BASH_SOURCE[0]}\")\")\" && pwd)\""
    ],
    "description": "current script directory"
  }
}
